{
  "expo": {
    "name": "FocusTrackMobile",
    "slug": "FocusTrackMobile",
    "version": "1.0.0",
    "sdkVersion": "55.0.0",
    "platforms": ["ios", "android", "web"],
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0e0e10"
      }
    }
  }
}
